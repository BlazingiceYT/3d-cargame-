<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
  <title>BlazingIce – City Racer</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: #0a0a0f; overflow: hidden; font-family: 'Courier New', monospace; touch-action: none; }
    #gameCanvas { display: block; width: 100vw; height: 100vh; }

    #speedometer {
      position: fixed; top: 16px; left: 50%; transform: translateX(-50%);
      color: #00ffcc; font-size: 11px; letter-spacing: 3px; text-transform: uppercase;
      text-shadow: 0 0 12px #00ffcc88; background: rgba(0,0,0,0.5);
      padding: 6px 18px; border: 1px solid #00ffcc44; border-radius: 4px; text-align: center;
    }
    #speedVal { font-size: 30px; font-weight: bold; display: block; line-height: 1.1; }

    #minimap {
      position: fixed; bottom: 230px; right: 16px;
      width: 100px; height: 100px;
      background: rgba(0,0,0,0.6); border: 1px solid #00ffcc44;
      border-radius: 4px; overflow: hidden;
    }
    #minimap canvas { width: 100%; height: 100%; }

    #controls {
      position: fixed; bottom: 0; left: 0; right: 0; height: 220px;
      display: flex; align-items: flex-end; justify-content: space-between;
      padding: 0 24px 32px; pointer-events: none; z-index: 20;
    }
    .btn-group { display: flex; gap: 12px; pointer-events: all; }
    .ctrl-btn {
      width: 70px; height: 70px; border-radius: 50%;
      border: 2px solid rgba(255,255,255,0.25); background: rgba(255,255,255,0.08);
      backdrop-filter: blur(6px); color: #fff; font-size: 22px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; user-select: none; -webkit-tap-highlight-color: transparent;
      touch-action: none;
    }
    .ctrl-btn.active { background: rgba(0,255,204,0.25); border-color: #00ffcc; }
    #btn-gas  { background: rgba(0,255,100,0.12); border-color: rgba(0,255,100,0.4); }
    #btn-brake { background: rgba(255,60,60,0.12); border-color: rgba(255,60,60,0.4); }
    #btn-gas.active   { background: rgba(0,255,100,0.35); border-color: #00ff64; }
    #btn-brake.active { background: rgba(255,60,60,0.35); border-color: #ff3c3c; }

    #loader {
      position: fixed; inset: 0; background: #0a0a0f;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      z-index: 100; transition: opacity 0.6s;
    }
    #loader h1 { color: #00ffcc; font-size: 28px; letter-spacing: 6px; text-shadow: 0 0 20px #00ffcc; margin-bottom: 8px; }
    #loader p  { color: #ffffff55; font-size: 11px; letter-spacing: 3px; }
    .loader-bar { width: 200px; height: 2px; background: #ffffff11; margin-top: 30px; border-radius: 2px; overflow: hidden; }
    .loader-fill { height: 100%; background: #00ffcc; width: 100%; box-shadow: 0 0 10px #00ffcc; }

    #hud-info {
      position: fixed; top: 16px; left: 16px;
      color: #ffffff88; font-size: 10px; letter-spacing: 1px; line-height: 1.8;
    }
  </style>
</head>
<body>

<div id="loader">
  <h1>BLAZINGICE</h1>
  <p>CITY RACER · LOADING</p>
  <div class="loader-bar"><div class="loader-fill"></div></div>
</div>

<canvas id="gameCanvas"></canvas>

<div id="speedometer">
  <span id="speedVal">0</span>KM/H
  <span id="driftMsg" style="color: #ffaa00; display: block; font-size: 9px; margin-top: 2px; font-weight: bold; opacity: 0; transition: opacity 0.1s;">DRIFTING</span>
</div>

<div id="hud-info">
  <div id="gear-info">DRIVE</div>
  <div id="ai-info">AI: 0</div>
</div>

<div id="minimap"><canvas id="mmCanvas" width="100" height="100"></canvas></div>

<div id="controls">
  <div class="btn-group">
    <div class="ctrl-btn" id="btn-left">◀</div>
    <div class="ctrl-btn" id="btn-right">▶</div>
  </div>
  <div class="btn-group">
    <div class="ctrl-btn" id="btn-brake">■</div>
    <div class="ctrl-btn" id="btn-gas">▲</div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/loaders/GLTFLoader.js"></script>
<script>
// ═══════════════════════════════════════════════
// RENDERER & SCENE SETUP
// ═══════════════════════════════════════════════
const canvas = document.getElementById('gameCanvas');
const renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5));
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.shadowMap.enabled = true;
renderer.shadowMap.type = THREE.PCFSoftShadowMap;
renderer.toneMapping = THREE.ACESFilmicToneMapping;
renderer.toneMappingExposure = 1.0;

const scene = new THREE.Scene();
scene.background = new THREE.Color(0xb4d6fa);
scene.fog = new THREE.FogExp2(0xb4d6fa, 0.0035);

const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 800);

scene.add(new THREE.AmbientLight(0xfff4e0, 1.2));
const sun = new THREE.DirectionalLight(0xfffbe8, 2.0);
sun.position.set(120, 200, 80);
sun.castShadow = true;
sun.shadow.mapSize.set(2048, 2048);
sun.shadow.camera.near = 1;
sun.shadow.camera.far  = 600;
sun.shadow.camera.left = -200;
sun.shadow.camera.bottom = -200;
sun.shadow.camera.right = 200;
sun.shadow.camera.top = 200;
sun.shadow.bias = -0.0005;
scene.add(sun);

// ═══════════════════════════════════════════════
// PROCEDURAL ENVIRONMENT GENERATION
// ═══════════════════════════════════════════════
const CITY_SIZE   = 240;  
const MAP_SIZE    = 600;  
const ROAD_W      = 12;    
const LANE_W      = 6;    
const BLOCK_SIZE  = 60;   

const matRoad     = new THREE.MeshStandardMaterial({ color: 0x222226, roughness: 0.8 });
const matPavement = new THREE.MeshStandardMaterial({ color: 0x707075, roughness: 0.7 });
const matGrass    = new THREE.MeshStandardMaterial({ color: 0x3d6e35, roughness: 0.9 });
const matDirt     = new THREE.MeshStandardMaterial({ color: 0x735735, roughness: 0.9 });
const matLine     = new THREE.MeshBasicMaterial({ color: 0xffffff });
const matYLine    = new THREE.MeshBasicMaterial({ color: 0xffcc00 });

const roads = []; 
const staticBuildings = [];
const streetLights = [];

function addRoad(x, z, w, d) {
  const mesh = new THREE.Mesh(new THREE.PlaneGeometry(w, d), matRoad);
  mesh.rotation.x = -Math.PI/2;
  mesh.position.set(x, 0.02, z);
  mesh.receiveShadow = true;
  scene.add(mesh);
  roads.push({ x, z, w, d });
  return mesh;
}

function addPavement(x, z, w, d) {
  const mesh = new THREE.Mesh(new THREE.PlaneGeometry(w, d), matPavement);
  mesh.rotation.x = -Math.PI/2;
  mesh.position.set(x, 0.015, z);
  mesh.receiveShadow = true;
  scene.add(mesh);
}

function addDashLine(x, z, w, d) {
  const m = new THREE.Mesh(new THREE.PlaneGeometry(w, d), matLine);
  m.rotation.x = -Math.PI/2;
  m.position.set(x, 0.025, z);
  scene.add(m);
}

function buildTerrain() {
  const ground = new THREE.Mesh(new THREE.PlaneGeometry(MAP_SIZE*4, MAP_SIZE*4), matGrass);
  ground.rotation.x = -Math.PI/2;
  ground.position.y = 0;
  ground.receiveShadow = true;
  scene.add(ground);

  for (let i = 0; i < 40; i++) {
    const side = Math.random() > 0.5 ? 1 : -1;
    const x = (Math.random() * 0.5 + 0.5) * MAP_SIZE * side;
    const z = (Math.random() * 2 - 1) * MAP_SIZE;
    const w = 40 + Math.random() * 60;
    const d = 30 + Math.random() * 50;
    const p = new THREE.Mesh(new THREE.PlaneGeometry(w, d), matDirt);
    p.rotation.x = -Math.PI/2;
    p.position.set(x, 0.01, z);
    p.receiveShadow = true;
    scene.add(p);
  }
}
buildTerrain();

function buildCityGrid() {
  const gridLines = [-120, -60, 0, 60, 120];

  gridLines.forEach(z => {
    addRoad(0, z, CITY_SIZE*2, ROAD_W);
    addPavement(0, z - ROAD_W/2 - 1.5, CITY_SIZE*2, 3);
    addPavement(0, z + ROAD_W/2 + 1.5, CITY_SIZE*2, 3);
    for (let x = -CITY_SIZE; x < CITY_SIZE; x += 10) {
      addDashLine(x + 2, z, 5, 0.4);
    }
  });

  gridLines.forEach(x => {
    addRoad(x, 0, ROAD_W, CITY_SIZE*2);
    addPavement(x - ROAD_W/2 - 1.5, 0, 3, CITY_SIZE*2);
    addPavement(x + ROAD_W/2 + 1.5, 0, 3, CITY_SIZE*2);
    for (let z = -CITY_SIZE; z < CITY_SIZE; z += 10) {
      addDashLine(x, z + 2, 0.4, 5);
    }
  });
}
buildCityGrid();

function buildHighways() {
  addRoad(0, (CITY_SIZE + MAP_SIZE)/2, ROAD_W + 4, MAP_SIZE - CITY_SIZE);
  addRoad(0, -(CITY_SIZE + MAP_SIZE)/2, ROAD_W + 4, MAP_SIZE - CITY_SIZE);
  addRoad((CITY_SIZE + MAP_SIZE)/2, 0, MAP_SIZE - CITY_SIZE, ROAD_W + 4);
  addRoad(-(CITY_SIZE + MAP_SIZE)/2, 0, MAP_SIZE - CITY_SIZE, ROAD_W + 4);

  for (let i = CITY_SIZE + 5; i < MAP_SIZE; i += 15) {
    const yl = new THREE.Mesh(new THREE.PlaneGeometry(0.5, 6), matYLine);
    yl.rotation.x = -Math.PI/2; yl.position.set(0, 0.026, i); scene.add(yl);
    const yl2 = yl.clone(); yl2.position.z = -i; scene.add(yl2);
    
    const yl3 = new THREE.Mesh(new THREE.PlaneGeometry(6, 0.5), matYLine);
    yl3.rotation.x = -Math.PI/2; yl3.position.set(i, 0.026, 0); scene.add(yl3);
    const yl4 = yl3.clone(); yl4.position.x = -i; scene.add(yl4);
  }

  const ringR = CITY_SIZE + 40;
  const segs = 72;
  for (let i = 0; i < segs; i++) {
    const a1 = (i / segs) * Math.PI * 2;
    const a2 = ((i + 1) / segs) * Math.PI * 2;
    const x1 = Math.cos(a1) * ringR, z1 = Math.sin(a1) * ringR;
    const x2 = Math.cos(a2) * ringR, z2 = Math.sin(a2) * ringR;
    const mx = (x1+x2)/2, mz = (z1+z2)/2;
    const len = Math.sqrt((x2-x1)**2 + (z2-z1)**2) + 0.8;
    const angle = Math.atan2(z2-z1, x2-x1);
    const seg = new THREE.Mesh(new THREE.PlaneGeometry(len, ROAD_W + 3), matRoad);
    seg.rotation.x = -Math.PI/2;
    seg.rotation.z = -angle;
    seg.position.set(mx, 0.018, mz);
    seg.receiveShadow = true;
    scene.add(seg);
    roads.push({ x: mx, z: mz, w: len, d: ROAD_W + 3 });
  }
}
buildHighways();

// ═══════════════════════════════════════════════
// STRUCTURAL CITY DESIGN & ASSETS
// ═══════════════════════════════════════════════
const buildingColors = [0x2f3640, 0x353b48, 0x718093, 0x1e272e, 0x485460, 0x2c3e50];

function makeBuilding(x, z, w, d, h, colorIdx) {
  const baseColor = buildingColors[colorIdx % buildingColors.length];
  const matFaçade = new THREE.MeshStandardMaterial({ color: baseColor, roughness: 0.6, metalness: 0.25 });
  const matWindowPane = new THREE.MeshStandardMaterial({ color: 0xdff9fb, emissive: 0xfbc531, emissiveIntensity: Math.random() * 0.4 + 0.1, roughness: 0.1, metalness: 0.9 });
  const matFrame = new THREE.MeshStandardMaterial({ color: 0x1e272e, roughness: 0.5, metalness: 0.8 });

  const buildingGroup = new THREE.Group();
  buildingGroup.position.set(x, 0, z);
  scene.add(buildingGroup);

  const coreMesh = new THREE.Mesh(new THREE.BoxGeometry(w, h, d), matFaçade);
  coreMesh.position.y = h / 2;
  coreMesh.castShadow = true;
  coreMesh.receiveShadow = true;
  buildingGroup.add(coreMesh);

  staticBuildings.push({ minX: x - w/2, maxX: x + w/2, minZ: z - d/2, maxZ: z + d/2 });

  if (h > 15) {
    const top = new THREE.Mesh(new THREE.BoxGeometry(w * 0.88, 2, d * 0.88), new THREE.MeshStandardMaterial({ color: 0x11141a, roughness: 0.8 }));
    top.position.set(0, h + 1, 0);
    top.castShadow = true;
    buildingGroup.add(top);
    
    const acUnit = new THREE.Mesh(new THREE.BoxGeometry(w * 0.15, 1.5, d * 0.15), matFrame);
    acUnit.position.set(w * 0.1, h + 1.75, d * 0.1);
    buildingGroup.add(acUnit);
  }

  const winW = 1.6; const winH = 2.4; const winDepth = 0.25; const floorH = 4.5; const paddingX = 2.2;
  const winPaneGeo = new THREE.BoxGeometry(winW, winH, winDepth);
  const winFrameGeo = new THREE.BoxGeometry(winW + 0.2, winH + 0.2, 0.08);

  for (let wy = floorH; wy < h - 3; wy += floorH) {
    const xCount = Math.floor((w - 4) / paddingX);
    const xStart = -((xCount - 1) * paddingX) / 2;
    for (let xi = 0; xi < xCount; xi++) {
      if (Math.random() > 0.08) {
        const curX = xStart + xi * paddingX;
        const frameF = new THREE.Mesh(winFrameGeo, matFrame); frameF.position.set(curX, wy, d / 2); buildingGroup.add(frameF);
        const paneF = new THREE.Mesh(winPaneGeo, matWindowPane); paneF.position.set(curX, wy, d / 2 - winDepth / 2 + 0.02); buildingGroup.add(paneF);
        const frameB = new THREE.Mesh(winFrameGeo, matFrame); frameB.position.set(curX, wy, -d / 2); buildingGroup.add(frameB);
        const paneB = new THREE.Mesh(winPaneGeo, matWindowPane); paneB.position.set(curX, wy, -d / 2 + winDepth / 2 - 0.02); buildingGroup.add(paneB);
      }
    }
    const zCount = Math.floor((d - 4) / paddingX);
    const zStart = -((zCount - 1) * paddingX) / 2;
    for (let zi = 0; zi < zCount; zi++) {
      if (Math.random() > 0.08) {
        const curZ = zStart + zi * paddingX;
        const frameR = new THREE.Mesh(winFrameGeo, matFrame); frameR.rotation.y = Math.PI / 2; frameR.position.set(w / 2, wy, curZ); buildingGroup.add(frameR);
        const paneR = new THREE.Mesh(winPaneGeo, matWindowPane); paneR.rotation.y = Math.PI / 2; paneR.position.set(w / 2 - winDepth / 2 + 0.02, wy, curZ); buildingGroup.add(paneR);
        const frameL = new THREE.Mesh(winFrameGeo, matFrame); frameL.rotation.y = Math.PI / 2; frameL.position.set(-w / 2, wy, curZ); buildingGroup.add(frameL);
        const paneL = new THREE.Mesh(winPaneGeo, matWindowPane); paneL.rotation.y = Math.PI / 2; paneL.position.set(-w / 2 + winDepth / 2 - 0.02, wy, curZ); buildingGroup.add(paneL);
      }
    }
  }
}

function buildCity() {
  const gridLines = [-120, -60, 0, 60, 120];
  let colorIdx = 0;
  for (let gi = 0; gi < gridLines.length - 1; gi++) {
    for (let gj = 0; gj < gridLines.length - 1; gj++) {
      const bx = (gridLines[gi] + gridLines[gi+1]) / 2;
      const bz = (gridLines[gj] + gridLines[gj+1]) / 2;
      const blockW = gridLines[gi+1] - gridLines[gi] - ROAD_W - 8;
      const blockD = gridLines[gj+1] - gridLines[gj] - ROAD_W - 8;

      const numBuildings = 1 + Math.floor(Math.random() * 2);
      if (numBuildings === 1) {
        const h = 12 + Math.random() * 45;
        makeBuilding(bx, bz, blockW * 0.8, blockD * 0.8, h, colorIdx++);
      } else {
        const splits = [[0.35, 0.35], [0.35, -0.35], [-0.35, 0.35], [-0.35, -0.35]];
        splits.slice(0, numBuildings + 1).forEach(([ox, oz]) => {
          const h = 8 + Math.random() * 28;
          makeBuilding(bx + ox * blockW, bz + oz * blockD, blockW*0.45, blockD*0.45, h, colorIdx++);
        });
      }
    }
  }
}
buildCity();

const trees = [];
function makeTree(x, z) {
  const g = new THREE.Group();
  const trunk = new THREE.Mesh(new THREE.CylinderGeometry(0.2, 0.35, 2.5, 6), new THREE.MeshStandardMaterial({ color: 0x4a321a, roughness: 0.9 }));
  trunk.position.y = 1.25; trunk.castShadow = true; g.add(trunk);

  const colors = [0x22543d, 0x2f7a4d, 0x1c4532, 0x38a169];
  const canopy = new THREE.Mesh(new THREE.ConeGeometry(2, 5, 7), new THREE.MeshStandardMaterial({ color: colors[Math.floor(Math.random()*colors.length)], roughness: 0.9 }));
  canopy.position.y = 4.5; canopy.castShadow = true; g.add(canopy);

  g.position.set(x, 0, z);
  g.userData = { alive: true, fallAngle: 0, fallDir: Math.random() > 0.5 ? 1 : -1, fallAxis: new THREE.Vector3(Math.random()-0.5, 0, Math.random()-0.5).normalize() };
  scene.add(g); trees.push(g);
}

function buildTrees() {
  for (let t = CITY_SIZE + 10; t < MAP_SIZE - 20; t += 18) {
    makeTree(8, t); makeTree(-8, t); makeTree(8, -t); makeTree(-8,-t);
    makeTree(t, 8); makeTree(t, -8); makeTree(-t, 8); makeTree(-t,-8);
  }
}
buildTrees();

function makeStreetLight(x, z) {
  const g = new THREE.Group();
  const pole = new THREE.Mesh(new THREE.CylinderGeometry(0.08, 0.1, 6, 6), new THREE.MeshStandardMaterial({ color: 0x4a4a52, metalness: 0.5, roughness: 0.4 }));
  pole.position.y = 3; pole.castShadow = true; g.add(pole);

  const head = new THREE.Mesh(new THREE.BoxGeometry(0.8, 0.2, 0.4), new THREE.MeshStandardMaterial({ color: 0x222226 })); head.position.set(0.3, 6.0, 0); g.add(head);
  const bulb = new THREE.Mesh(new THREE.SphereGeometry(0.15, 6, 6), new THREE.MeshBasicMaterial({ color: 0xfffee0 })); bulb.position.set(0.5, 5.85, 0); g.add(bulb);

  g.position.set(x, 0, z); scene.add(g);
  streetLights.push({ x, z, radius: 0.3 });
}

[-120,-60,0,60,120].forEach(x => {
  [-120,-60,0,60,120].forEach(z => { if(x !== 0 || z !== 0) makeStreetLight(x + ROAD_W/2 + 0.8, z + ROAD_W/2 + 0.8); });
});

// ═══════════════════════════════════════════════
// CAR ENTITIES & INTERACTION ROOT SET
// ═══════════════════════════════════════════════
const carGroup = new THREE.Group();
carGroup.position.set(0, 0, 15);
scene.add(carGroup);

// Structural Sub-node to enable body visual roll/pitch animations independent of world kinematics
const carBodyVisual = new THREE.Group();
carGroup.add(carBodyVisual);

const fallbackBody = new THREE.Mesh(new THREE.BoxGeometry(2.0, 0.6, 4.2), new THREE.MeshStandardMaterial({ color: 0xe53e3e, roughness: 0.2, metalness: 0.5 }));
fallbackBody.position.y = 0.5; fallbackBody.castShadow = true; fallbackBody.receiveShadow = true; carBodyVisual.add(fallbackBody);

const fallbackCabin = new THREE.Mesh(new THREE.BoxGeometry(1.4, 0.5, 2.0), new THREE.MeshStandardMaterial({ color: 0x1a202c, roughness: 0.1 }));
fallbackCabin.position.set(0, 1.0, -0.2); fallbackCabin.castShadow = true; carBodyVisual.add(fallbackCabin);

const gltfLoader = new THREE.GLTFLoader();
gltfLoader.load('CL1M02.glb', (gltf) => {
  carBodyVisual.remove(fallbackBody); carBodyVisual.remove(fallbackCabin);
  const model = gltf.scene;
  const box = new THREE.Box3().setFromObject(model);
  const size = new THREE.Vector3(); const center = new THREE.Vector3();
  box.getSize(size); box.getCenter(center);
  const scale = 4.5 / Math.max(size.x, size.y, size.z);
  model.scale.setScalar(scale);
  model.position.x = -center.x * scale;
  model.position.z = -center.z * scale;
  const box2 = new THREE.Box3().setFromObject(model);
  model.position.y = -box2.min.y; model.rotation.y = Math.PI;
  model.traverse(c => { if (c.isMesh) { c.castShadow = true; c.receiveShadow = true; } });
  carBodyVisual.add(model);
});

// AI Traffic Setup
const AI_COLORS = [0x2b6cb0, 0xdd6b20, 0x38a169, 0xb7791f, 0x319795, 0x4c51bf, 0xe53e3e];
const allWaypoints = [[-120,-120],[-120,0],[-120,120],[0,-120],[0,120],[120,-120],[120,0],[120,120]];

function makeAICar(color) {
  const g = new THREE.Group();
  const body = new THREE.Mesh(new THREE.BoxGeometry(2, 0.6, 4), new THREE.MeshStandardMaterial({ color, roughness: 0.3, metalness: 0.2 }));
  body.position.y = 0.5; body.castShadow = true; g.add(body);
  const cabin = new THREE.Mesh(new THREE.BoxGeometry(1.4, 0.5, 2), new THREE.MeshStandardMaterial({ color: 0x222226, roughness: 0.2 }));
  cabin.position.set(0, 1.0, -0.1); cabin.castShadow = true; g.add(cabin);
  return g;
}

const aiCars = [];
const NUM_AI = 16;
for (let i = 0; i < NUM_AI; i++) {
  const wp = allWaypoints[Math.floor(Math.random() * allWaypoints.length)];
  const car = makeAICar(AI_COLORS[i % AI_COLORS.length]);
  car.position.set(wp[0] + (Math.random()-0.5)*12, 0, wp[1] + (Math.random()-0.5)*12);
  car.userData = { speed: 12 + Math.random()*6, wpIdx: Math.floor(Math.random() * allWaypoints.length), angle: Math.random() * Math.PI * 2 };
  scene.add(car); aiCars.push(car);
}

function updateAI(dt) {
  aiCars.forEach(car => {
    const target = allWaypoints[car.userData.wpIdx % allWaypoints.length];
    const dx = target[0] - car.position.x; const dz = target[1] - car.position.z;
    const dist = Math.sqrt(dx*dx + dz*dz);
    if (dist < 15) { car.userData.wpIdx = (car.userData.wpIdx + 1) % allWaypoints.length; return; }
    const targetAngle = Math.atan2(dx, dz);
    let angleDiff = targetAngle - car.userData.angle;
    while (angleDiff > Math.PI) angleDiff -= Math.PI*2;
    while (angleDiff < -Math.PI) angleDiff += Math.PI*2;
    car.userData.angle += Math.sign(angleDiff) * Math.min(Math.abs(angleDiff), 1.5 * dt);
    car.position.x += Math.sin(car.userData.angle) * car.userData.speed * dt;
    car.position.z += Math.cos(car.userData.angle) * car.userData.speed * dt;
    car.rotation.y = car.userData.angle;
  });
}

function checkTreeCollisions() {
  trees.forEach(tree => {
    if (!tree.userData.alive) {
      if (tree.userData.fallAngle < Math.PI/2) {
        tree.userData.fallAngle += 0.06; tree.rotateOnAxis(tree.userData.fallAxis, 0.06 * tree.userData.fallDir);
      }
      return;
    }
    const dx = carGroup.position.x - tree.position.x; const dz = carGroup.position.z - tree.position.z;
    if (Math.sqrt(dx*dx+dz*dz) < 2.2) tree.userData.alive = false;
  });
}

// ═══════════════════════════════════════════════
// INPUT CONTROLLERS
// ═══════════════════════════════════════════════
const keys = { gas:false, brake:false, left:false, right:false };

document.addEventListener('keydown', e => {
  if (e.key==='ArrowUp'   || e.key==='w' || e.key==='W') keys.gas=true;
  if (e.key==='ArrowDown' || e.key==='s' || e.key==='S') keys.brake=true;
  if (e.key==='ArrowLeft' || e.key==='a' || e.key==='A') keys.left=true;
  if (e.key==='ArrowRight'|| e.key==='d' || e.key==='D') keys.right=true;
});
document.addEventListener('keyup', e => {
  if (e.key==='ArrowUp'   || e.key==='w' || e.key==='W') keys.gas=false;
  if (e.key==='ArrowDown' || e.key==='s' || e.key==='S') keys.brake=false;
  if (e.key==='ArrowLeft' || e.key==='a' || e.key==='A') keys.left=false;
  if (e.key==='ArrowRight'|| e.key==='d' || e.key==='D') keys.right=false;
});

function bindBtn(id, key) {
  const el = document.getElementById(id);
  const on  = () => { keys[key]=true; el.classList.add('active'); };
  const off = () => { keys[key]=false; el.classList.remove('active'); };
  el.addEventListener('touchstart', e=>{e.preventDefault();on();},{passive:false});
  el.addEventListener('touchend',   e=>{e.preventDefault();off();},{passive:false});
  el.addEventListener('mousedown', on); el.addEventListener('mouseup', off); el.addEventListener('mouseleave',off);
}
bindBtn('btn-gas',  'gas'); bindBtn('btn-brake','brake'); bindBtn('btn-left', 'left'); bindBtn('btn-right','right');

// ═══════════════════════════════════════════════
// ADVANCED FORZA-STYLE PHYSICS INITIALIZATION
// ═══════════════════════════════════════════════
let carX = 0, carZ = 15, carAngle = 0;
let forwardVelocity = 0;
let lateralVelocity = 0; // Vector velocity component moving sideways (crucial for drifting)
let steerAngle = 0;
let isDrifting = false;

// Physics Parameters Tuning Configs (Forza Horizon/Racing Master balancing presets)
const MAX_SPEED      = 52;    // Increased top-end baseline cap
const ACCEL_RATE     = 20;    
const BRAKE_FORCE    = 38;    
const NATURAL_DRAG   = 4.5;   
const GRIP_STATIC    = 8.5;   // Normal tire adherence multiplier
const GRIP_SLIP      = 2.2;   // Reduced slide friction multiplier once breaking traction
const DRIFT_THRESH   = 6.5;   // Speed/Slip ratio threshold triggering slip breakaway
const WEIGHT_TRANSFER = 0.04;  // Mesh geometry rolling coefficient

// ═══════════════════════════════════════════════
// MINIMAP ENGINE
// ═══════════════════════════════════════════════
const mmCanvas = document.getElementById('mmCanvas');
const mmCtx    = mmCanvas.getContext('2d');
const MM_SIZE  = 100;
const MM_SCALE = MM_SIZE / (MAP_SIZE * 2);

function drawMinimap() {
  mmCtx.clearRect(0,0,MM_SIZE,MM_SIZE);
  mmCtx.fillStyle = '#1c2d1f'; mmCtx.fillRect(0,0,MM_SIZE,MM_SIZE);
  mmCtx.fillStyle = '#3a3a40';
  roads.forEach(r => {
    const mx = (r.x + MAP_SIZE) * MM_SCALE; const mz = (r.z + MAP_SIZE) * MM_SCALE;
    mmCtx.fillRect(mx - (r.w*MM_SCALE)/2, mz - (r.d*MM_SCALE)/2, r.w*MM_SCALE, r.d*MM_SCALE);
  });
  const px = (carX + MAP_SIZE) * MM_SCALE; const pz = (carZ + MAP_SIZE) * MM_SCALE;
  mmCtx.fillStyle = '#00ffcc'; mmCtx.beginPath(); mmCtx.arc(px, pz, 2.5, 0, Math.PI*2); mmCtx.fill();
}

// ═══════════════════════════════════════════════
// COLLISION RESOLUTION ENGINE
// ═══════════════════════════════════════════════
function resolveCollisions() {
  staticBuildings.forEach(b => {
    const testX = Math.max(b.minX, Math.min(carX, b.maxX));
    const testZ = Math.max(b.minZ, Math.min(carZ, b.maxZ));
    const diffX = carX - testX; const diffZ = carZ - testZ;
    const dist = Math.sqrt(diffX * diffX + diffZ * diffZ);
    if (dist < 1.3) {
      let overlap = 1.3 - dist;
      if (dist === 0) { carZ = b.minZ - 1.3; } 
      else { carX += (diffX / dist) * overlap; carZ += (diffZ / dist) * overlap; }
      forwardVelocity *= -0.3; lateralVelocity *= 0.2; isDrifting = false;
    }
  });

  streetLights.forEach(l => {
    const dx = carX - l.x; const dz = carZ - l.z;
    const dist = Math.sqrt(dx * dx + dz * dz);
    if (dist < 1.4) {
      carX += (dx / dist) * (1.4 - dist); carZ += (dz / dist) * (1.4 - dist);
      forwardVelocity *= -0.3; isDrifting = false;
    }
  });
}

// ═══════════════════════════════════════════════
// CORE VEHICLE PHYSICS & LOOP CONTEXT
// ═══════════════════════════════════════════════
const clock = new THREE.Clock();
const speedEl = document.getElementById('speedVal');
const driftMsgEl = document.getElementById('driftMsg');
const gearEl = document.getElementById('gear-info');

function update(dt) {
  // 1. INPUT HANDLE & ACCELERATION KINEMATICS
  if (keys.gas) {
    forwardVelocity = Math.min(forwardVelocity + ACCEL_RATE * dt, MAX_SPEED);
  } else if (keys.brake) {
    forwardVelocity = Math.max(forwardVelocity - BRAKE_FORCE * dt, -MAX_SPEED * 0.4);
  } else {
    if (forwardVelocity > 0) forwardVelocity = Math.max(0, forwardVelocity - NATURAL_DRAG * dt);
    if (forwardVelocity < 0) forwardVelocity = Math.min(0, forwardVelocity + NATURAL_DRAG * dt);
  }

  // 2. SPEED-SENSITIVE STEERING RATIONALE (Tight turns at low speed, stable at high speed)
  const normSpeed = Math.abs(forwardVelocity) / MAX_SPEED;
  const currentMaxSteer = 0.55 - (normSpeed * 0.28); // Dynamic Lock angle modification
  const currentSteerSpeed = 3.5 - (normSpeed * 1.2);

  if (keys.left) {
    steerAngle = Math.min(steerAngle + currentSteerSpeed * dt, currentMaxSteer);
  } else if (keys.right) {
    steerAngle = Math.max(steerAngle - currentSteerSpeed * dt, -currentMaxSteer);
  } else {
    steerAngle *= Math.exp(-9.0 * dt); // Quick self-centering steering return
  }

  // 3. SEPARATE TWO-AXIS VELOCITY DRIFT MATRIX MECHANICS
  // Extract world coordinates to relative vehicle chassis reference space
  const currentFwdX = Math.sin(carAngle);
  const currentFwdZ = Math.cos(carAngle);
  const currentLatX = Math.sin(carAngle + Math.PI / 2);
  const currentLatZ = Math.cos(carAngle + Math.PI / 2);

  // Calculate actual relative lateral speed (how much the car is sliding sideways)
  // Inertial momentum preserves side slide during high angle heading changes
  if (Math.abs(forwardVelocity) > 1.0) {
    // Turning applies a high-speed centrifugal force pushing the car outwards
    const turnCentrifugalFactor = steerAngle * forwardVelocity * 1.3;
    lateralVelocity += turnCentrifugalFactor * dt;
  }

  // Drift initiation criteria: Breaking traction if turning hard while dragging brakes
  const slipAngleValue = Math.abs(lateralVelocity);
  if (slipAngleValue > DRIFT_THRESH && Math.abs(forwardVelocity) > 12) {
    if (keys.brake || Math.abs(steerAngle) > currentMaxSteer * 0.75) {
      isDrifting = true;
    }
  }
  
  // Continuous drift exit validation logic
  if (slipAngleValue < 1.8 || Math.abs(forwardVelocity) < 6) {
    isDrifting = false;
  }

  // Apply friction forces depending on traction state (Static grip vs Sliding friction coefficient)
  const currentGripFriction = isDrifting ? GRIP_SLIP : GRIP_STATIC;
  lateralVelocity *= Math.exp(-currentGripFriction * dt);

  // 4. ANGULAR MOMENTUM MODULATION (Yaw rate update loop)
  if (Math.abs(forwardVelocity) > 0.5) {
    const dir = forwardVelocity > 0 ? 1.0 : -1.0;
    // Boost rotational torque response while drifting to enable counter-steering control loops
    const driftYawEnhancement = isDrifting ? 1.65 : 1.15;
    carAngle += steerAngle * forwardVelocity * 0.026 * driftYawEnhancement * dt * dir;
  }

  // Convert localized relative calculations back into absolute global Cartesian positions
  carX += (currentFwdX * forwardVelocity + currentLatX * lateralVelocity) * dt;
  carZ += (currentFwdZ * forwardVelocity + currentLatZ * lateralVelocity) * dt;

  // Collision handling constraints pass
  resolveCollisions();

  const LIM = MAP_SIZE - 12;
  if (carX >  LIM) { carX =  LIM; forwardVelocity *= -0.3; isDrifting = false; }
  if (carX < -LIM) { carX = -LIM; forwardVelocity *= -0.3; isDrifting = false; }
  if (carZ >  LIM) { carZ =  LIM; forwardVelocity *= -0.3; isDrifting = false; }
  if (carZ < -LIM) { carZ = -LIM; forwardVelocity *= -0.3; isDrifting = false; }

  // 5. RENDERING VISUAL ARTIFACT MANIPULATION (Weight Shift Roll & Pitch)
  carGroup.position.set(carX, 0, carZ);
  
  // Injecting counter-steer offset visual flair into raw rotation orientation
  const visualDriftYawOffset = isDrifting ? -lateralVelocity * 0.018 : 0;
  carGroup.rotation.y = carAngle + visualDriftYawOffset;

  // Simulate body roll suspension flexing based on lateral G-forces and pitch on hard deceleration
  const targetRoll = -lateralVelocity * WEIGHT_TRANSFER * 0.25;
  const targetPitch = (keys.brake && forwardVelocity > 5) ? 0.04 : 0;
  
  carBodyVisual.rotation.z += (targetRoll - carBodyVisual.rotation.z) * 0.15;
  carBodyVisual.rotation.x += (targetPitch - carBodyVisual.rotation.x) * 0.15;

  // 6. DYNAMIC DRIFT-AWARE CAMERA SYSTEM (Smooth lagging tracking camera)
  const cameraTargetDist = 13.5;
  const cameraTargetHeight = 4.2;

  // The camera trails behind the vehicle path vector but blends smoothly into the slide direction
  const camLookAheadAngle = carAngle + (isDrifting ? visualDriftYawOffset * 0.4 : steerAngle * 0.25);
  const targetCamX = carX - Math.sin(camLookAheadAngle) * cameraTargetDist;
  const targetCamZ = carZ - Math.cos(camLookAheadAngle) * cameraTargetDist;

  camera.position.x += (targetCamX - camera.position.x) * 0.12;
  camera.position.y += (cameraTargetHeight - camera.position.y) * 0.12;
  camera.position.z += (targetCamZ - camera.position.z) * 0.12;

  // Focus look-at parameters forward into space along motion profile arrays
  camera.lookAt(carX + Math.sin(carAngle) * 9.0, 0.8, carZ + Math.cos(carAngle) * 9.0);

  // Synchronize Shadow cascades
  sun.position.set(carX + 120, 200, carZ + 80);
  if(sun.target !== carGroup) sun.target = carGroup;

  updateAI(dt);
  checkTreeCollisions();

  // Metrics interface parsing
  const displaySpeed = Math.abs(Math.round(forwardVelocity * 4.4));
  speedEl.textContent = displaySpeed;
  gearEl.textContent = forwardVelocity >= 0 ? "DRIVE" : "REVERSE";
  driftMsgEl.style.opacity = isDrifting ? "1" : "0";

  drawMinimap();
}

function animate() {
  requestAnimationFrame(animate);
  const dt = Math.min(clock.getDelta(), 0.03); // Cap step variance delta intervals
  update(dt);
  renderer.render(scene, camera);
}

window.addEventListener('resize', () => {
  camera.aspect = window.innerWidth / window.innerHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(window.innerWidth, window.innerHeight);
});

animate();
setTimeout(() => {
  const loader = document.getElementById('loader');
  loader.style.opacity = '0';
  setTimeout(() => loader.remove(), 600);
}, 1000);
</script>
